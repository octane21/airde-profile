PORT=4000
FRONTEND_URL=http://localhost:5173

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

ADMIN_USERNAME=admin
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=

# Public URL of this backend, used to build file URLs (e.g. https://your-app.up.railway.app).
# Defaults to http://localhost:<PORT> if left empty.
PUBLIC_BASE_URL=

# Postgres connection string (Render, Neon, Supabase, or local Postgres)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=
# Set to "false" only if connecting to a local Postgres without SSL
PGSSL=

# Get from https://console.groq.com/keys — powers the AIRDE Assistant chatbot (/api/chat)
GROQ_API_KEY=
